# Production or EC2 runtime environment template
# Replace placeholder values before use.

DATABASE_URL=postgresql+psycopg2://postgres:<password>@<rds-endpoint>:5432/postgres
TEAMMATE_PREFS_KEY=<fernet-key>
CORS_ORIGINS=http://localhost:5173

# OTP email delivery via AWS SES
AWS_REGION=us-east-1
OTP_SES_SOURCE_EMAIL=otp@yourdomain.com
OTP_EMAIL_SUBJECT=Your OTP Code

# Optional: route all OTP emails to a single inbox during testing
OTP_FORWARD_TO_EMAIL=

# Optional: static OTP for local testing only (leave empty in production)
OTP_STATIC_CODE=

# Keep false for normal deploys. Set true only for one-time seed run.
RUN_DB_SEEDS=false

